{
  "rewrites": [
    { "source": "/data/member.js",    "destination": "/api/data?file=member.js"    },
    { "source": "/data/raid.js",      "destination": "/api/data?file=raid.js"      },
    { "source": "/data/character.js", "destination": "/api/data?file=character.js" }
  ],
  "functions": {
    "api/data.js": {
      "includeFiles": "api/_data/**"
    }
  },
  "headers": [
    {
      "source": "/css/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=3600" }]
    },
    {
      "source": "/image/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }]
    }
  ]
}
